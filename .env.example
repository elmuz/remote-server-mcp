# Environment variables for Remote Server MCP
# Copy to .env and update with your settings

# MCP server settings
MCP_LOG_LEVEL=INFO

# SSH credentials (alternative to config.yaml)
SSH_HOST=your-server.example.com
SSH_PORT=22
SSH_USERNAME=your-username
# SSH_PASSWORD=your-password
SSH_KEY_PATH=~/.ssh/id_rsa
SSH_USE_SUDO=true
